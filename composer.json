{
    "name": "mcandylab/laravel-cuid2",
    "description": "CUID2 support for Laravel",
    "keywords": [
        "mcandylab",
        "laravel-cuid2"
    ],
    "homepage": "https://github.com/mcandylab/laravel-cuid2",
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Andrey Abramov",
            "email": "an.abramov@internet.ru",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0",
        "visus/cuid2": "^6.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.24",
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "Mcandylab\\LaravelCuid2\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Mcandylab\\LaravelCuid2\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "test-coverage": "vendor/bin/phpunit --coverage-html coverage"

    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mcandylab\\LaravelCuid2\\LaravelCuid2ServiceProvider"
            ],
            "aliases": {
                "LaravelCuid2": "Mcandylab\\LaravelCuid2\\LaravelCuid2Facade"
            }
        }
    }
}
